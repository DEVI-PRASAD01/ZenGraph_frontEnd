<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.READ_MEDIA_AUDIO" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" tools:ignore="ScopedStorage" />
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.ZenGraph"
        android:usesCleartextTraffic="true">

        <!-- Firebase Messaging Service -->
        <service
            android:name=".notifications.ZenNotificationService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>

        <!-- Daily Reminder Receiver -->
        <receiver
            android:name=".notifications.DailyReminderReceiver"
            android:exported="true"
            android:permission="android.permission.RECEIVE_BOOT_COMPLETED" />

        <!-- 🔥 ADD THIS EXACTLY HERE -->
        <receiver android:name=".notifications.StopAlarmReceiver" />

        <activity
            android:name=".SplashActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity android:name=".AuthChoiceActivity" android:theme="@style/Theme.ZenGraph.Auth" />
        <activity android:name=".SignupActivity" android:theme="@style/Theme.ZenGraph.Auth" />
        <activity android:name=".LoginActivity" android:theme="@style/Theme.ZenGraph.Auth" />
        <activity android:name=".ForgotPasswordActivity" android:theme="@style/Theme.ZenGraph.Auth" />
        <activity android:name=".OtpActivity" android:theme="@style/Theme.ZenGraph.Auth" />
        <activity android:name=".ResetPasswordActivity" android:theme="@style/Theme.ZenGraph.Auth" />
        <activity android:name=".NotificationsSettingsActivity" android:exported="false" />
        <activity android:name=".FaqActivity" android:exported="false" />
        <activity android:name=".SettingsActivity" />
        <activity android:name=".EditProfileActivity" />
        <activity android:name=".PrivacyDataActivity" />
        <activity android:name=".SubscriptionActivity" />
        <activity android:name=".MainActivity" />
        <activity android:name=".GoalSelectionActivity" android:screenOrientation="portrait" />
        <activity android:name=".FeelingSelectionActivity" android:screenOrientation="portrait" />
        <activity android:name=".ExpressYourselfActivity" android:screenOrientation="portrait" />
        <activity android:name=".AiAnalysisActivity" android:screenOrientation="portrait" />
        <activity android:name=".ExperienceSelectionActivity" android:screenOrientation="portrait" />
        <activity android:name=".SessionActivity" android:screenOrientation="portrait" />
        <activity android:name=".AiPlanActivity" android:screenOrientation="portrait" />
        <activity android:name=".SessionReadyActivity" android:screenOrientation="portrait" />
        <activity android:name=".LiveSessionActivity" android:screenOrientation="portrait" />
        <activity android:name=".SessionCompleteActivity" android:screenOrientation="portrait" />
        <activity android:name=".ReflectionActivity" android:screenOrientation="portrait" />
        <activity android:name=".PostSessionAiActivity" android:screenOrientation="portrait" />
        <activity android:name=".ProgressDashboardActivity" android:screenOrientation="portrait" />
        <activity android:name=".PersonalizedInsightsActivity" android:screenOrientation="portrait" />
        <activity android:name=".AnalyticsDashboardActivity" android:screenOrientation="portrait" />
        <activity android:name=".MeditationPlanActivity" android:screenOrientation="portrait" />
        <activity android:name=".ContentLibraryActivity" android:screenOrientation="portrait" />
        <activity android:name=".MeditationLibraryActivity" android:screenOrientation="portrait" />
        <activity android:name=".VoiceAnalysisActivity" android:screenOrientation="portrait" />
        <activity android:name=".SchedulerActivity" android:screenOrientation="portrait" />
        <activity android:name=".ProfileSettingsActivity" android:screenOrientation="portrait" />
        <activity android:name=".RewardSystemActivity" android:screenOrientation="portrait" />
        <activity android:name=".OnboardingWelcomeActivity"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.ZenGraph.Auth" />
        <activity android:name=".HistoryActivity" android:screenOrientation="portrait" />
        <activity android:name=".FriendsActivity" android:screenOrientation="portrait" />

        <activity android:name=".ChatActivity" />
        <activity android:name=".MeditationSessionActivity" android:screenOrientation="portrait" />

        <!-- ✅ Reminder Activity -->
        <activity android:name=".ReminderActivity" android:screenOrientation="portrait" />

    </application>

</manifest>