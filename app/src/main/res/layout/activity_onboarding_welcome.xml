<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_onboarding_welcome">

    <!-- Top Star-like Decorations (Minimalist version for now) -->
    <ImageView
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_margin="16dp"
        android:alpha="0.3"
        android:src="@android:drawable/btn_star_big_on"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="#FFFFFF" />

    <ImageView
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_margin="40dp"
        android:alpha="0.2"
        android:src="@android:drawable/btn_star_big_on"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="#FFFFFF" />

    <!-- Speech Bubble -->
    <FrameLayout
        android:id="@+id/speechBubbleContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        app:layout_constraintBottom_toTopOf="@id/ivMascot"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <ImageView
            android:layout_width="220dp"
            android:layout_height="110dp"
            android:scaleType="fitXY"
            android:src="@drawable/bg_speech_bubble" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:paddingBottom="10dp"
            android:fontFamily="sans-serif-medium"
            android:gravity="center"
            android:paddingHorizontal="32dp"
            android:text="Start Your\nMindful Journey"
            android:textColor="#1A202C"
            android:textSize="22sp" />
    </FrameLayout>

    <!-- Mascot -->
    <ImageView
        android:id="@+id/ivMascot"
        android:layout_width="280dp"
        android:layout_height="280dp"
        android:layout_marginTop="180dp"
        android:scaleType="fitCenter"
        android:src="@drawable/ic_brain_mascot_placeholder"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Shadows / Ground Decorations -->
    <View
        android:layout_width="140dp"
        android:layout_height="12dp"
        android:alpha="0.1"
        android:background="@drawable/bg_accent_circle"
        app:layout_constraintBottom_toBottomOf="@id/ivMascot"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/ivMascot"
        app:tint="#000000" />

    <!-- Main Text Content -->
    <LinearLayout
        android:id="@+id/contentGroup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="32dp"
        android:layout_marginTop="32dp"
        android:orientation="vertical"
        app:layout_constraintTop_toBottomOf="@id/ivMascot">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-black"
            android:text="Step Into"
            android:textColor="#1A202C"
            android:textSize="44sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-black"
            android:text="Your Peaceful"
            android:textColor="#1A202C"
            android:textSize="44sp" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/tvMind"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-black"
                android:text="Mind"
                android:textColor="#1A202C"
                android:textSize="44sp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <ImageView
                android:layout_width="140dp"
                android:layout_height="70dp"
                android:scaleType="fitXY"
                android:src="@drawable/ic_mind_circle"
                app:layout_constraintBottom_toBottomOf="@id/tvMind"
                app:layout_constraintEnd_toEndOf="@id/tvMind"
                app:layout_constraintStart_toStartOf="@id/tvMind"
                app:layout_constraintTop_toTopOf="@id/tvMind" />

            <TextView
                android:layout_width="160dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:text="Breathe deeply, relax fully, and find calm."
                android:textColor="#4A5568"
                android:textSize="14sp"
                app:layout_constraintBottom_toBottomOf="@id/tvMind"
                app:layout_constraintStart_toEndOf="@id/tvMind"
                app:layout_constraintTop_toTopOf="@id/tvMind" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </LinearLayout>

    <!-- Get Started Button -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/btnGetStarted"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:layout_marginHorizontal="32dp"
        android:layout_marginBottom="48dp"
        android:background="@drawable/bg_glass_card"
        android:backgroundTint="#1A202C"
        android:paddingHorizontal="16dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <ImageView
            android:id="@+id/btnIcon"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:padding="8dp"
            android:src="@drawable/ic_brain_mascot_placeholder"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="#FFFFFF" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-bold"
            android:text="Get Started"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=">>>"
            android:textColor="#66FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
