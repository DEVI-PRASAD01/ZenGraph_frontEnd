<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="20dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <FrameLayout
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:layout_marginEnd="14dp">

                <View
                    android:id="@+id/viewInitialsCircle"
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:background="@drawable/circle_teal_bg"/>

                <TextView
                    android:id="@+id/tvInitials"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"/>

                <!-- Unread Badge -->
                <TextView
                    android:id="@+id/tvUnreadBadge"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="top|end"
                    android:background="@drawable/circle_amber_light_bg"
                    android:backgroundTint="#D85A30"
                    android:gravity="center"
                    android:textColor="#FFFFFF"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:visibility="gone"
                    android:elevation="2dp" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvFriendName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A2E"/>

                <TextView
                    android:id="@+id/tvMeditatedStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textColor="#1D9E75"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginEnd="10dp">

                <TextView
                    android:id="@+id/tvStreakCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="#1D9E75"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="day streak"
                    android:textSize="10sp"
                    android:textColor="#BBBBBB"/>
            </LinearLayout>

            <FrameLayout
                android:id="@+id/layoutFlame"
                android:layout_width="44dp"
                android:layout_height="44dp">

                <View
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/circle_amber_light_bg"/>

                <ImageView
                    android:id="@+id/ivFlame"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_local_fire_department"/>
            </FrameLayout>

        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnNudge"
            android:layout_width="match_parent"
            android:layout_height="42dp"
            android:layout_marginTop="12dp"
            android:text="Nudge to meditate today"
            android:textSize="13sp"
            android:textColor="#D85A30"
            app:backgroundTint="#FFF3EE"
            app:cornerRadius="12dp"
            app:strokeColor="#F0997B"
            app:strokeWidth="1dp"
            android:visibility="gone"/>

    </LinearLayout>
</androidx.cardview.widget.CardView>
