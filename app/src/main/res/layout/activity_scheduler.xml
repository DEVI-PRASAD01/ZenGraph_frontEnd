<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_ethereal_gradient">

    <TextView
        android:id="@+id/schedulerTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="64dp"
        android:text="Practice Reminder"
        android:textColor="@color/text_primary"
        android:textSize="26sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- AI Suggestion Card -->
    <LinearLayout
        android:id="@+id/aiSuggestionCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="32dp"
        android:background="@drawable/bg_glass_card"
        android:backgroundTint="@color/glass_white_less"
        android:orientation="vertical"
        android:padding="24dp"
        app:layout_constraintTop_toBottomOf="@id/schedulerTitle">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AI Smart Suggestion"
                android:textColor="@color/accent_teal"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Based on your biology, 7:15 AM is the best time for your morning focus session."
                android:textColor="@color/text_primary"
                android:textSize="16sp" />

            <android.widget.Button
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_marginTop="16dp"
                android:paddingHorizontal="24dp"
                android:background="@drawable/bg_glass_circle"
                android:backgroundTint="@color/glass_white"
                android:text="Apply 7:15 AM"
                android:textAllCaps="false"
                android:textColor="@color/accent_teal"
                android:textSize="12sp"
                android:textStyle="bold" />
    </LinearLayout>

    <!-- Custom Time Picker Placeholder -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="24dp"
        android:background="@drawable/bg_glass_card"
        android:backgroundTint="@color/glass_white_less"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="32dp"
        app:layout_constraintTop_toBottomOf="@id/aiSuggestionCard">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="07:15"
            android:textColor="@color/text_primary"
            android:textSize="64sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tap to change daily reminder"
            android:textColor="@color/text_secondary"
            android:textSize="12sp" />
    </LinearLayout>

    <android.widget.Button
        android:id="@+id/btnSaveSchedule"
        style="@style/EtherealButton"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginBottom="40dp"
        android:text="Save Schedule"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
