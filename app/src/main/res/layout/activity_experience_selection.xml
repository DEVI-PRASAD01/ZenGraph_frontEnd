<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_onboarding_welcome">

    <LinearLayout
        android:id="@+id/backButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="24dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackground"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_back"
            app:tint="#1A202C" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="Back"
            android:textColor="#1A202C"
            android:textSize="14sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="40dp"
        android:layout_marginTop="32dp"
        android:gravity="center"
        android:text="Meditation Experience"
        android:textColor="#1A202C"
        android:textSize="32sp"
        android:fontFamily="sans-serif-black"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/backButton" />

    <TextView
        android:id="@+id/subtitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="60dp"
        android:layout_marginTop="16dp"
        android:gravity="center"
        android:text="Select your experience level"
        android:textColor="#4A5568"
        android:textSize="16sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/title" />

    <!-- Experience Cards -->
    <LinearLayout
        android:id="@+id/cardContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="32dp"
        android:layout_marginTop="32dp"
        android:orientation="vertical"
        app:layout_constraintTop_toBottomOf="@id/subtitle">

        <!-- Beginner Card -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/cardBeginner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_glass_card"
            android:backgroundTint="#FFFFFF"
            android:padding="20dp"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:id="@+id/emojiBeginner"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🌱"
                android:textSize="24sp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

            <TextView
                android:id="@+id/titleBeginner"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:text="Beginner"
                android:textColor="#1A202C"
                android:textSize="18sp"
                android:fontFamily="sans-serif-bold"
                app:layout_constraintStart_toEndOf="@id/emojiBeginner"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="2dp"
                android:text="“New to meditation”"
                android:textColor="#4A5568"
                android:textSize="14sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/emojiBeginner"
                app:layout_constraintTop_toBottomOf="@id/titleBeginner" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Intermediate Card -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/cardIntermediate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_glass_card"
            android:backgroundTint="#FFFFFF"
            android:padding="20dp"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:id="@+id/emojiIntermediate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🌿"
                android:textSize="24sp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

            <TextView
                android:id="@+id/titleIntermediate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:text="Intermediate"
                android:textColor="#1A202C"
                android:textSize="18sp"
                android:fontFamily="sans-serif-bold"
                app:layout_constraintStart_toEndOf="@id/emojiIntermediate"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="2dp"
                android:text="“Some experience”"
                android:textColor="#4A5568"
                android:textSize="14sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/emojiIntermediate"
                app:layout_constraintTop_toBottomOf="@id/titleIntermediate" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Advanced Card -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/cardAdvanced"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_glass_card"
            android:backgroundTint="#FFFFFF"
            android:padding="20dp"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:id="@+id/emojiAdvanced"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🧘"
                android:textSize="24sp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

            <TextView
                android:id="@+id/titleAdvanced"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:text="Advanced"
                android:textColor="#1A202C"
                android:textSize="18sp"
                android:fontFamily="sans-serif-bold"
                app:layout_constraintStart_toEndOf="@id/emojiAdvanced"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="2dp"
                android:text="“Meditate regularly”"
                android:textColor="#4A5568"
                android:textSize="14sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/emojiAdvanced"
                app:layout_constraintTop_toBottomOf="@id/titleAdvanced" />
        </androidx.constraintlayout.widget.ConstraintLayout>

    </LinearLayout>

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/continueButton"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_marginHorizontal="32dp"
        android:layout_marginBottom="48dp"
        android:background="@drawable/bg_glass_card"
        android:backgroundTint="#1A202C"
        android:fontFamily="sans-serif-bold"
        android:text="Continue"
        android:textAllCaps="false"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:alpha="0.5"
        android:enabled="false"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
