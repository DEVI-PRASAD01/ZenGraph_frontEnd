<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.ZenGraph" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/accent_teal</item>
        <item name="android:windowBackground">@drawable/bg_ethereal_gradient</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
    </style>

    <style name="Theme.ZenGraph" parent="Base.Theme.ZenGraph">
        <item name="android:statusBarColor">@color/ethereal_bg_start</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">true</item>
        <item name="android:navigationBarColor">@color/ethereal_bg_end</item>
    </style>

    <!-- Auth / Onboarding Theme: clean white background -->
    <style name="Theme.ZenGraph.Auth" parent="Theme.ZenGraph">
        <item name="android:windowBackground">@color/white_pure</item>
        <item name="android:statusBarColor">@color/white_pure</item>
        <item name="android:navigationBarColor">@color/white_pure</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">true</item>
    </style>

    <!-- Glass Styles -->
    <style name="GlassCard" parent="">
        <item name="android:background">@drawable/bg_glass_card</item>
        <item name="android:elevation">4dp</item>
    </style>

    <style name="EtherealButton" parent="Widget.Material3.Button">
        <item name="android:background">@drawable/bg_ethereal_button</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/white_pure</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
    </style>

</resources>