<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Shadow for 3D effect -->
    <item>
        <shape>
            <corners android:radius="32dp" />
            <solid android:color="#1A000000" />
        </shape>
    </item>
    
    <!-- Main Glass Body -->
    <item android:bottom="4dp" android:left="1dp" android:right="1dp" android:top="1dp">
        <shape>
            <corners android:radius="32dp" />
            <gradient
                android:angle="270"
                android:endColor="#CCFFFFFF"
                android:startColor="#E6FFFFFF" />
            <stroke
                android:width="1dp"
                android:color="@color/glass_border" />
        </shape>
    </item>
</layer-list>
